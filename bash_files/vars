DEVBOX_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
export PATH="$PATH:$HOME/bin:$HOME/.local/bin:$DEVBOX_ROOT/bin${EC2_HOME:+:$EC2_HOME/bin}"
export VISUAL='vim'
export EDITOR="$VISUAL"
export KOPS_STATE_STORE='s3://clusters.kube.stacksource.co'
export USE_GKE_GCLOUD_AUTH_PLUGIN=True

# Prevent tmux from closing panes on Ctrl+D
export IGNOREEOF=3

# This is for terraform in various projects like townsquare and go-links.
# I don't know if this is the optimal solution, more of just a get it
# working thing.
export AWS_PROFILE=tf-default

